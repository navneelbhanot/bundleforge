{% comment %}
  MintBundle — Build-a-Box Stepper (M-090).
  Multi-step picker that walks customers through the bundle's
  config.steps[].
{% endcomment %}
{% schema %}
{
  "name": "MintBundle Build-a-Box",
  "target": "section",
  "settings": [
    { "type": "text", "id": "slug",  "label": "Bundle slug" },
    { "type": "checkbox", "id": "show_progress", "label": "Show progress bar", "default": true }
  ]
}
{% endschema %}
<mintbundle-build-box
  data-slug="{{ block.settings.slug | escape }}"
  data-show-progress="{{ block.settings.show_progress }}">
  <p class="mintbundle-loading">Loading box builder…</p>
</mintbundle-build-box>
<script src="{{ 'mintbundle-bundle.js' | asset_url }}" type="module" defer></script>
