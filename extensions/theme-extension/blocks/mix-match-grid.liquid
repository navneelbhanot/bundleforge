{% comment %}
  MintBundle — Mix-and-Match Grid (M-091).
  Grid of selectable items with min/max enforcement.
{% endcomment %}
{% schema %}
{
  "name": "MintBundle Mix-and-Match",
  "target": "section",
  "settings": [
    { "type": "text", "id": "slug",     "label": "Bundle slug" },
    { "type": "range", "id": "columns", "label": "Columns", "min": 2, "max": 5, "step": 1, "default": 3 }
  ]
}
{% endschema %}
<mintbundle-mix-match
  data-slug="{{ block.settings.slug | escape }}"
  data-columns="{{ block.settings.columns }}">
  <p class="mintbundle-loading">Loading…</p>
</mintbundle-mix-match>
<script src="{{ 'mintbundle-bundle.js' | asset_url }}" type="module" defer></script>
