{% comment %}
  BundleForge Theme Extension — Bundle Display Block
  This App Block renders the bundle widget on product pages.
{% endcomment %}

{% schema %}
{
  "name": "BundleForge Bundle",
  "target": "section",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Bundle Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "list", "label": "List" },
        { "value": "carousel", "label": "Carousel" }
      ],
      "default": "grid"
    },
    {
      "type": "checkbox",
      "id": "show_compare_price",
      "label": "Show Compare at Price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_savings_badge",
      "label": "Show Savings Badge",
      "default": true
    }
  ]
}
{% endschema %}

<div id="bundleforge-widget"
  data-product-id="{{ product.id }}"
  data-layout="{{ block.settings.layout }}"
  data-show-compare="{{ block.settings.show_compare_price }}"
  data-show-badge="{{ block.settings.show_savings_badge }}"
  data-shop="{{ shop.permanent_domain }}">
  <!-- BundleForge widget renders here via JS -->
  <div class="bundleforge-loading">
    <p>Loading bundle...</p>
  </div>
</div>

<script src="{{ 'bundleforge-widget.js' | asset_url }}" defer></script>
