{% comment %}
  BundleForge — Bundle Display Block (M-088)

  Renders a bundle widget on the product page. The widget is a custom
  element (`<bundleforge-bundle>`) that fetches the bundle config from
  the App Proxy at /apps/bundleforge/bundle/<slug>.
{% endcomment %}

{% schema %}
{
  "name": "BundleForge Bundle",
  "target": "section",
  "settings": [
    { "type": "text",     "id": "slug",                "label": "Bundle slug" },
    { "type": "select",   "id": "layout",              "label": "Layout",
      "options": [
        { "value": "grid",     "label": "Grid" },
        { "value": "list",     "label": "List" },
        { "value": "carousel", "label": "Carousel" }
      ],
      "default": "grid" },
    { "type": "checkbox", "id": "show_compare_price",  "label": "Show compare price",  "default": true },
    { "type": "checkbox", "id": "show_savings_badge",  "label": "Show savings badge",  "default": true }
  ]
}
{% endschema %}

<bundleforge-bundle
  data-slug="{{ block.settings.slug | escape }}"
  data-shop="{{ shop.permanent_domain }}"
  data-product-id="{{ product.id }}"
  data-layout="{{ block.settings.layout }}"
  data-show-compare="{{ block.settings.show_compare_price }}"
  data-show-badge="{{ block.settings.show_savings_badge }}">
  <p class="bundleforge-loading">Loading bundle…</p>
</bundleforge-bundle>

<script src="{{ 'bundleforge-bundle.js' | asset_url }}" type="module" defer></script>
<link rel="stylesheet" href="{{ 'bundleforge.css' | asset_url }}">
