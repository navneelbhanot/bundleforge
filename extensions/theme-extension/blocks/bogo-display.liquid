{% comment %}
  MintBundle — BOGO Display (M-092).
  Renders the buy-X-get-Y promotion banner + cart-aware progress.
{% endcomment %}
{% schema %}
{
  "name": "MintBundle BOGO",
  "target": "section",
  "settings": [
    { "type": "text", "id": "slug",          "label": "Bundle slug" },
    { "type": "text", "id": "headline",      "label": "Headline", "default": "Buy X, get Y free" },
    { "type": "checkbox", "id": "show_progress", "label": "Show progress meter", "default": true }
  ]
}
{% endschema %}
<mintbundle-bogo
  data-slug="{{ block.settings.slug | escape }}"
  data-show-progress="{{ block.settings.show_progress }}">
  <p class="mintbundle-bogo-headline">{{ block.settings.headline }}</p>
</mintbundle-bogo>
<script src="{{ 'mintbundle-bundle.js' | asset_url }}" type="module" defer></script>
