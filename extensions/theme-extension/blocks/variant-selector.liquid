{% comment %}
  MintBundle — Variant Selector Block (M-089).
  Renders <mintbundle-variant-picker> for a single bundle item.
{% endcomment %}
{% schema %}
{
  "name": "MintBundle Variant Picker",
  "target": "section",
  "settings": [
    { "type": "text", "id": "slug",      "label": "Bundle slug" },
    { "type": "text", "id": "item_index", "label": "Item index", "default": "0" }
  ]
}
{% endschema %}
<mintbundle-variant-picker
  data-slug="{{ block.settings.slug | escape }}"
  data-item-index="{{ block.settings.item_index }}">
</mintbundle-variant-picker>
<script src="{{ 'mintbundle-bundle.js' | asset_url }}" type="module" defer></script>
