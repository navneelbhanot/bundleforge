# Variables Railway injects automatically (don't set):
#   DATABASE_URL  — from the Postgres plugin
#   REDIS_URL     — from the Redis plugin
#   PORT          — Railway routes traffic to whatever PORT we listen on

# Variables you must set in the Railway dashboard:
NODE_ENV=production
LOG_LEVEL=info

# Shopify Partners app credentials (Settings → API credentials)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,write_products,read_orders,read_fulfillments,read_customers,read_inventory,write_inventory,read_themes,write_themes,read_locales

# Public URL Railway issued for the web service (e.g. bundleforge.up.railway.app)
SHOPIFY_APP_URL=https://your-app.up.railway.app
SHOPIFY_AUTH_CALLBACK_PATH=/api/auth/callback

# 32-byte hex; generate once with `openssl rand -hex 32` and never rotate
# without re-encrypting all Shop.accessToken rows.
ENCRYPTION_KEY=

# Optional observability
SENTRY_DSN=
DATADOG_API_KEY=

# AI microservice. Deploy ai-service/ as a separate Railway service and
# paste its URL here.
AI_SERVICE_URL=
AI_SERVICE_TOKEN=
