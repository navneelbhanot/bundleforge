{
  "name": "bundleforge",
  "version": "0.1.0",
  "description": "BundleForge — The most reliable Shopify product bundling app",
  "private": true,
  "scripts": {
    "dev": "shopify app dev",
    "build": "prisma generate && vite build -c frontend/vite.config.ts",
    "build:server": "prisma generate",
    "build:frontend": "vite build -c frontend/vite.config.ts",
    "start": "node scripts/start-web.cjs",
    "start:web": "node scripts/start-web.cjs",
    "start:worker": "node scripts/start-worker.cjs",
    "start:webhooks-worker": "node scripts/start-webhooks-worker.cjs",
    "release": "prisma migrate deploy",
    "audit:prod": "npm audit --omit=dev",
    "docs:openapi": "node scripts/check-openapi.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit && tsc --noEmit -p frontend/tsconfig.json",
    "typecheck:server": "tsc --noEmit",
    "typecheck:frontend": "tsc --noEmit -p frontend/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "worker": "tsx src/jobs/worker.ts",
    "shopify": "shopify",
    "postinstall": "node scripts/install-extensions.cjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "~6.18.0",
    "@prisma/client": "~6.18.0",
    "@sentry/node": "^10.51.0",
    "@shopify/app-bridge-react": "^4.1.0",
    "@shopify/polaris": "^12.27.0",
    "@shopify/shopify-api": "^13.0.0",
    "@shopify/shopify-app-express": "^7.0.0",
    "@shopify/shopify-app-session-storage-memory": "^6.0.0",
    "@shopify/shopify-app-session-storage-prisma": "^9.0.0",
    "@types/supertest": "^7.2.0",
    "bullmq": "^5.12.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "helmet": "^7.1.0",
    "i18next": "^26.0.10",
    "ioredis": "^5.4.1",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^11.3.0",
    "prisma": "~6.18.0",
    "rate-limiter-flexible": "^5.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.7",
    "react-router-dom": "^6.26.0",
    "resend": "^4.8.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "uuid": "^10.0.0",
    "winston": "^3.14.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@shopify/cli": "^3.94.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.6",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "axe-core": "^4.11.4",
    "esbuild": "^0.28.0",
    "eslint": "^9.9.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "javy-cli": "^3.0.1",
    "jsdom": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.59.1",
    "vite": "^5.4.2",
    "vitest": "^2.0.5",
    "vitest-axe": "^0.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
