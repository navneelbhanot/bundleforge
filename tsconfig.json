{
  "compilerOptions": {
    "target": "ES2022",
    // CommonJS at runtime (Node + ts-node + vitest), but the type-resolver
    // uses Bundler so `exports` is honored — required for Shopify SDK v13
    // which ships source `.ts` files alongside the dist `.d.ts`.
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDirs": ["./src", "./tests", "./extensions"],
    "allowJs": false,
    "checkJs": false,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@/*": ["./src/*"],
      "@services/*": ["./src/services/*"],
      "@routes/*": ["./src/routes/*"],
      "@middleware/*": ["./src/middleware/*"],
      "@utils/*": ["./src/utils/*"],
      "@types/*": ["./src/types/*"],
      "@config/*": ["./src/config/*"],
      "@jobs/*": ["./src/jobs/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "extensions",
    "src/generated"
  ]
}
