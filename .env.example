# =============================================================================
# BundleForge — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
#
# Validated by src/config/env.ts at boot. Every key listed here corresponds to
# exactly one entry in the Zod schema there. A meta-test enforces that the two
# stay in sync.
#
# Lines beginning with `#` are treated as documentation. To enable an optional
# key, uncomment the line and provide a value.
# =============================================================================

# ── Shopify App ──
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_SCOPES=read_products,write_products,read_orders,write_orders,read_inventory,write_inventory,read_customers,read_themes,write_cart_transforms,read_locations,read_publications,write_publications
SHOPIFY_APP_URL=https://your-app-url.com
SHOPIFY_AUTH_CALLBACK_PATH=/api/auth/callback

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql://user:password@host:5432/bundleforge?sslmode=require

# ── Redis ──
REDIS_URL=redis://default:password@host:6379

# ── Encryption ──
# Generate a fresh key with:  openssl rand -hex 32
# Must be exactly 64 hex characters (32 bytes for AES-256-GCM).
ENCRYPTION_KEY=replace_me_with_64_hex_chars_replace_me_with_64_hex_chars_xxxxxxxx

# ── Application ──
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
APP_NAME=BundleForge
APP_VERSION=0.1.0

# ── AI Recommendation Service (optional; set both or neither) ──
# AI_SERVICE_URL=http://localhost:5001
# AI_SERVICE_API_KEY=your_ai_service_key

# ── Sentry (optional) ──
# SENTRY_DSN=https://public@sentry.example.com/1

# ── Crisp live chat (optional) ──
# When set, the embedded admin lazy-loads Crisp's widget so merchants
# can talk to support without leaving the app. Get the website id from
# https://app.crisp.chat -> Settings -> Website ID.
# CRISP_WEBSITE_ID=00000000-0000-0000-0000-000000000000

# ── Support page links (M-187, all optional) ──
# Read by the SPA at build time (Vite-prefixed). Each is rendered on
# /support as an external link in the Resources card; if unset, the
# link is hidden so the page never shows dead anchors.
# VITE_SUPPORT_EMAIL defaults to support@bundleforge.app if unset.
# VITE_SUPPORT_EMAIL=support@bundleforge.app
# VITE_CHANGELOG_URL=https://bundleforge.app/changelog
# VITE_STATUS_URL=https://status.bundleforge.app
# VITE_GITHUB_REPO_URL=https://github.com/your-org/bundleforge/issues
